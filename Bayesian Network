\n","model.check_model()\n","\n","# Query the model for the probability of COVID-19 given a set of symptoms\n","from pgmpy.inference import VariableElimination\n","\n","infer = VariableElimination(model)\n","q = infer.query(['covid'], evidence={'fever': 1, 'cough': 1, 'fatigue': 1})\n","print(q)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"xipIPvkrEVxo","executionInfo":{"status":"ok","timestamp":1681816546457,"user_tz":-330,"elapsed":448,"user":{"displayName":"Yuvan Velkumar Sukumar","userId":"07971017809612896470"}},"outputId":"4bce9453-64c7-4b82-a9ba-629631454b83"},"execution_count":56,"outputs":[{"output_type":"stream","name":"stdout","text":["+----------+--------------+\n","| covid    |   phi(covid) |\n","+==========+==============+\n","| covid(0) |       0.0010 |\n","+----------+--------------+\n","| covid(1) |       0.9990 |\n","+----------+--------------+\n"]},{"output_type":"stream","name":"stderr","text":["/usr/local/lib/python3.9/dist-packages/pgmpy/models/BayesianModel.py:8: FutureWarning: BayesianModel has been renamed to BayesianNetwork. Please use BayesianNetwork class, BayesianModel will be removed in future.\n","  warnings.warn(\n"]}]},{"cell_type":"code","source":[],"metadata":{"id":"_9eYg8wSE-VC"},"execution_count":null,"outputs":[]}]}