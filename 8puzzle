{"nbformat":4,"nbformat_minor":0,"metadata":{"colab":{"provenance":[]},"kernelspec":{"name":"python3","display_name":"Python 3"},"language_info":{"name":"python"}},"cells":[{"cell_type":"code","source":[" #This functions prints the result\n","def print_in_format (matrix):\n","    for i in range(9):\n","        if i%3 == 0 and i > 0:# This line is use to print the list in 3x3 matrix print(\"\") gives new line\n","            print(\" \")\n","        print (str(matrix [i])+\" \", end =\"\" )\n","\n","def count (s) :#This func use to check the goal and state\n","# state and count must be equal then the condition becomes true and exit\n","    c = 0\n","    goal = [1, 2, 3,\n","    4, 5, 6,\n","    7, 8, 0]\n","    for i in range(9) :\n","        if s[i]!= 0 and s[i] != goal [i]:\n","            c += 1 #increment\n","    return c\n","#st = state\n","#p = position\n","#ar = arr\n","def move(ar, p, st):\n","    rh = 999999\n","    store_st = st.copy ()\n","\n","    for i in range(len (ar) ):\n","        dupl_st = st.copy()\n","\n","        temp = dupl_st[p] #p = position\n","        dupl_st[p] = dupl_st[arr[i]]\n","        dupl_st[arr[i]] = temp\n","        tmp_rh = count(dupl_st)#function call count to check the sorted list\n","\n","        if tmp_rh <rh:\n","            rh = tmp_rh\n","            store_st = dupl_st.copy()\n","\n","    return store_st, rh # return the value to while func\n","\n","state = [1, 2, 3,\n","0, 5, 6,\n","4, 7, 8]\n","h = count(state)# function call count & def count returns the value h\n","Level = 1\n","print(\"\\n-- ---- Level \"+str(Level) + \" - ----- \")\n","print_in_format (state)\n","print(\"\\nHeuristic Value (MispLaced): \"+str(h))\n","while h>0:\n","    pos = int (state. index (0))\n","    Level += 1\n","    if pos == 0:\n","        arr =[1, 3]\n","        state, h = move(arr, pos, state)\n","\n","    elif pos == 1:\n","        arr = [0, 2, 4]\n","        state, h= move(arr, pos, state)\n","    elif pos==2:\n","        arr= [1, 5]\n","        state, h = move(arr, pos, state)\n","    elif pos==3:\n","        arr = [0, 4, 6]\n","        state, h = move(arr, pos, state)\n","    elif pos==4:\n","        arr = [1, 3, 5, 7]\n","        state, h = move(arr, pos, state)\n","    elif pos==5:\n","        arr = [2, 4, 8]\n","        state, h = move (arr, pos, state)\n","    elif pos==6:\n","        arr = [3, 7]\n","        state, h = move(arr, pos, state)\n","    elif pos==7:\n","\n","        arr = [4, 6, 8]\n","        state, h = move(arr, pos, state)\n","    elif pos==8:\n","        arr = [5, 6]\n","        state, h = move(arr, pos, state)\n","\n","    print(\"\\n-- ---- Level \"+str(Level) + \" - ----- \")\n","    print_in_format (state)\n","    print(\"\\nHeuristic Value (MispLaced): \"+str(h))\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"-FlOXKzMLY84","executionInfo":{"status":"ok","timestamp":1670941620694,"user_tz":-330,"elapsed":9,"user":{"displayName":"Prithiv Raaj Nagaraj","userId":"05806920679121630755"}},"outputId":"fb3690e0-5f2b-46cb-fc67-20afea6b47ae"},"execution_count":1,"outputs":[{"output_type":"stream","name":"stdout","text":["\n","-- ---- Level 1 - ----- \n","1 2 3  \n","0 5 6  \n","4 7 8 \n","Heuristic Value (MispLaced): 3\n","\n","-- ---- Level 2 - ----- \n","1 2 3  \n","4 5 6  \n","0 7 8 \n","Heuristic Value (MispLaced): 2\n","\n","-- ---- Level 3 - ----- \n","1 2 3  \n","4 5 6  \n","7 0 8 \n","Heuristic Value (MispLaced): 1\n","\n","-- ---- Level 4 - ----- \n","1 2 3  \n","4 5 6  \n","7 8 0 \n","Heuristic Value (MispLaced): 0\n"]}]}]}